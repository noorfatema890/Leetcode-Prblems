class Solution(object):
    def isValid(self,s):
        try:
            tracker = []
            brackets = {')': '(', '}': '{', ']': '['}

            if not (1 <= len(s) <= 10**4):
                return False
        
            allowed_chars = set("()[]{}")
            for char in s:
                if char not in allowed_chars:
                    return False
        
            for char in s:
                if char in brackets:
                    if len(tracker) == 0:
                        return False
                    if tracker[-1] != brackets[char]:
                        return False
                    tracker.pop()
                else:
                    tracker.append(char)
        
            if len(tracker) == 0:
                return True
            else:
                return False
    
        except Exception as e:
            return False


        
