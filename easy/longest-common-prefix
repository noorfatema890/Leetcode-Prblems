class Solution(object):
    def longestCommonPrefix(self, strs):
        """
        :type strs: List[str]
        :rtype: str
        """
        if 200>=len(strs)>=1:
            prefix = strs[0]
            for i in strs[1:]:
                if 200>=len(i)>=1:
                    while not i.startswith(prefix):
                        prefix = prefix[:-1]
                        if not prefix:
                            return ""
                else:
                    return ''
            return prefix
        else:
            return 'Not acceptable length'
        
